      "outputSchema": {
        "type": "object",
        "properties": {
          "decision":    { "type": "string", "enum": ["APPROVE", "WARN", "BLOCK"] },
          "riskScore":   { "type": "number", "description": "0-100, higher = more dangerous" },
          "reasons":     { "type": "array", "items": { "type": "string" } },
          "recommendation": { "type": "string" }
